# Subscription URL (single, shared across all instances)
SUBSCRIPTION_URL=

# Comma-separated subscription URLs (one per instance, overrides SUBSCRIPTION_URL)
# SUBSCRIPTION_URLS=https://sub1.example,https://sub2.example,https://sub3.example

# URL used to test proxy connectivity
HEALTH_CHECK_URL=http://api.ipify.org

# Number of xray instances to run
PROXY_INSTANCES=1

# Base port for proxy allocation (each instance gets 2 consecutive ports)
PORT_BASE=27019

# Port for the HTTP API (returns live proxy list)
API_PORT=27018

# Path to xray binary directory (default: /root/xray)
# XRAY_DIR=/root/xray

# Go garbage collector target percentage (lower = more frequent GC, less memory)
# GOGC=100

# Go soft memory limit (prevents OOM by triggering aggressive GC)
# GOMEMLIMIT=128MiB

# Max concurrent HTTP CONNECT relay connections (prevents goroutine/memory explosion)
# MAX_CONNS=128
